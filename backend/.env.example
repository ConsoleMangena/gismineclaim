PORT=3000
ACCESS_TOKEN_SECRET=replace-with-at-least-32-characters-long-access-secret
REFRESH_TOKEN_SECRET=replace-with-at-least-32-characters-long-refresh-secret
ACCESS_TOKEN_EXPIRES_IN=1d
REFRESH_TOKEN_EXPIRES_IN=7d
API_RATE_LIMIT=1000
AUTH_RATE_LIMIT=25

DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=replace-with-db-password
DB_HOST=localhost
DB_PORT=5432
DB_SSLMODE=require

CORS_ALLOWED_ORIGINS=http://localhost:5173
